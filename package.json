{
  "name": "ghl-hubspot-migration",
  "version": "1.0.0",
  "description": "ETL pipeline for GoHighLevel → HubSpot CRM data migration",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "extract": "node src/extract/index.js",
    "transform": "node src/transform/index.js",
    "load": "node src/load/index.js",
    "test:ghl": "node scripts/test-ghl-connection.js",
    "schema:hs": "node scripts/pull-hubspot-schema.js",
    "sample:ghl": "node scripts/sample-ghl-contacts.js",
    "sample:ghl-endpoints": "node scripts/sample-ghl-endpoints.js",
    "extract:sample": "node scripts/extract-sample.js",
    "extract:wb": "node scripts/extract-workshop-buyers.js",
    "extract:wb:resume": "node scripts/extract-workshop-buyers.js --resume",
    "extract:pb": "node scripts/extract-preview-buyers.js",
    "extract:pb:resume": "node scripts/extract-preview-buyers.js --resume",
    "extract:reg": "node scripts/extract-registrants.js",
    "extract:reg:sample": "node scripts/extract-registrants.js --count=100",
    "extract:reg:resume": "node scripts/extract-registrants.js --resume",
    "pilot": "node scripts/pilot-run.js",
    "validate": "node src/validation/index.js",
    "create-properties": "node scripts/create-hubspot-properties.js",
    "build:owner-map": "node scripts/build-owner-map.js",
    "sample:opportunity": "node scripts/sample-opportunity.js",
    "migrate:tier1": "node scripts/migrate-tier.js --tier=1",
    "migrate:tier2": "node scripts/migrate-tier.js --tier=2",
    "migrate:tier3": "node scripts/migrate-tier.js --tier=3",
    "report:tier1": "node scripts/migration-report.js --tier=1",
    "report:tier2": "node scripts/migration-report.js --tier=2",
    "report:tier3": "node scripts/migration-report.js --tier=3",
    "dedup:pull": "node scripts/dedup-hubspot.js --pull",
    "dedup:dry-run": "node scripts/dedup-hubspot.js --dry-run",
    "dedup:merge": "node scripts/dedup-hubspot.js --merge",
    "validate:pilot": "node scripts/validate-pilot.js",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.0",
    "p-limit": "^5.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
