# GoHighLevel (via LeadConnector / Engager)
GHL_ENGAGER_SECRET_KEY=your_engager_secret_key_here
GHL_LOCATION_ID=your_location_id
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_VERSION=2021-07-28
GHL_ENGAGER_TOKEN_URL=https://api.engager.ai/get-token

# Sampling script (scripts/sample-ghl-contacts.js)
GHL_SAMPLE_LIMIT=100
GHL_SAMPLE_OUTPUT_PATH=./data/samples/ghl-sample-100.json

# HubSpot (Service Key — Super Admin level)
HUBSPOT_API_KEY=your_hubspot_service_key_here
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_PORTAL_ID=your_portal_id

# Migration Settings
BATCH_SIZE=100
BATCH_DELAY_MS=1500
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_PER_SECOND=10

# Checkpointing
CHECKPOINT_DIR=./data/checkpoints
LOG_DIR=./logs

# Environment
NODE_ENV=development
